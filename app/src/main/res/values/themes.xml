<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.SimonSaysGPS.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FFF8E2</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_system_icon</item>
        <item name="windowSplashScreenAnimationDuration">220</item>
        <item name="postSplashScreenTheme">@style/Theme.SimonSaysGPS</item>
    </style>

    <style name="Theme.SimonSaysGPS" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
    </style>
</resources>
